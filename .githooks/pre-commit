#!/bin/sh
set -eu

echo "---------- Git hook: pre-commit ----------"

# Ruff (imports, lint, and format)
echo ""
echo ">>> [1/7] Running Ruff"
ruff check --select I .
ruff check .
ruff format --check .

# Flake8 (lint)
echo ""
echo ">>> [2/7] Running Flake8"
flake8 .

# MyPy (type checking)
echo ""
echo ">>> [3/7] Running MyPy"
mypy .

# Pyright (type checking)
echo ""
echo ">>> [4/7] Running Pyright"
pyright .

# Ty (type checking)
echo ""
echo ">>> [5/7] Running Ty"
ty check . --error-on-warning

# Pyrefly (type checking)
echo ""
echo ">>> [6/7] Running Pyrefly"
pyrefly check .

# Run tests
echo ""
echo ">>> [7/7] Running tests"
coverage run -m unittest discover .
coverage report --fail-under=90

echo "------------------------------------------"
